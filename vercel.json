{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "strk20-by-example.vercel.app" }],
      "destination": "https://strk20-by-example.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "strk20-by-example-gray.vercel.app" }],
      "destination": "https://strk20-by-example.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "strk20-by-example-starkiences-projects.vercel.app" }
      ],
      "destination": "https://strk20-by-example.org/$1",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
